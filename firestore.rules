rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if request has admin session
    function isAdmin() {
      // Admin check is performed server-side via session cookie
      // This rule set provides protection at the Firestore level
      // Allow writes only from authenticated backend (future: implement custom claims)
      return false; // For now, all writes must go through API routes
    }

    // Public read-only access to enabled products
    match /adminProducts/{productId} {
      allow read: if resource.data.status == "enabled";
      allow create, update, delete: if isAdmin();
    }

    // Public read-only access to orders (customers shouldn't read, but allow for now)
    match /orders/{orderId} {
      allow create: if request.resource.data.customerName != null && 
                       request.resource.data.phone != null &&
                       request.resource.data.address != null;
      allow read, update, delete: if isAdmin();
    }

    // Admin access only
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    // Activity logs - server-side writes only, admin reads
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if false; // Only server API writes allowed
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
